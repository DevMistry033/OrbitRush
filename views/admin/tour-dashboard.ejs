<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard | OrbitRush Tourism</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Cormorant+Garamond:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #fbfcf8;
        --bg-soft: #f3f8f0;
        --surface: #ffffff;
        --surface-soft: #f7faf5;
        --text: #173b28;
        --text-muted: #708678;
        --line: #d8e6d5;
        --line-soft: #e8f0e5;
        --primary: #1d5a33;
        --primary-dark: #134224;
        --primary-soft: #e5f0e7;
        --gold: #f1c94b;
        --danger: #d9534f;
        --shadow-sm: 0 12px 28px rgba(17, 53, 30, 0.08);
        --shadow-md: 0 22px 44px rgba(17, 53, 30, 0.12);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: linear-gradient(180deg, var(--bg-soft) 0%, var(--bg) 100%);
        color: var(--text);
      }

      .header {
        background: rgba(255, 255, 255, 0.96);
        border-bottom: 1px solid var(--line);
        box-shadow: 0 10px 24px rgba(17, 53, 30, 0.05);
        padding: 1rem 2rem;
      }

      .header-content {
        max-width: 1320px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .admin-title {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary);
      }

      .admin-nav {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .admin-nav a {
        color: var(--primary);
        text-decoration: none;
        padding: 0.8rem 1.1rem;
        border-radius: 14px;
        border: 1px solid transparent;
        font-weight: 600;
        transition: all 0.2s ease;
      }

      .admin-nav a:hover {
        background: var(--primary-soft);
        border-color: var(--line);
      }

      .admin-nav .nav-strong {
        background: var(--primary);
        color: white;
      }

      .admin-nav .nav-strong:hover {
        background: var(--primary-dark);
        border-color: var(--primary-dark);
      }

      .container {
        max-width: 1320px;
        margin: 0 auto;
        padding: 2.2rem;
      }

      .dashboard-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
      }

      .page-title-wrap h1 {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2.7rem, 4vw, 4rem);
        line-height: 0.95;
        margin-bottom: 0.35rem;
        color: var(--text);
      }

      .page-title-wrap p {
        color: var(--text-muted);
        line-height: 1.7;
      }

      .header-actions {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
      }

      .action-btn {
        min-height: 52px;
        padding: 0.9rem 1.25rem;
        border-radius: 16px;
        text-decoration: none;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        border: 1px solid var(--line);
        transition: all 0.2s ease;
        box-shadow: var(--shadow-sm);
      }

      .action-btn.primary {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
      }

      .action-btn.primary:hover {
        background: var(--primary-dark);
        border-color: var(--primary-dark);
      }

      .action-btn.secondary {
        background: #fff;
        color: var(--primary);
      }

      .action-btn.secondary:hover {
        background: var(--primary-soft);
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.2rem;
        margin-bottom: 2rem;
      }

      .stat-card {
        background: var(--surface);
        border: 1px solid var(--line-soft);
        border-radius: 22px;
        padding: 1.35rem;
        box-shadow: var(--shadow-sm);
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .stat-icon {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        color: white;
        background: linear-gradient(135deg, #2b7b45, #1d5a33);
      }

      .stat-icon.revenue {
        background: linear-gradient(135deg, #f3d971, #e0b938);
        color: #23422a;
      }

      .stat-content h3 {
        font-size: 1.9rem;
        line-height: 1;
        font-weight: 800;
        color: var(--text);
      }

      .stat-content p {
        margin-top: 0.25rem;
        color: var(--text-muted);
        font-size: 0.9rem;
      }

      .tours-section {
        background: var(--surface);
        border: 1px solid var(--line-soft);
        border-radius: 28px;
        padding: 1.7rem;
        box-shadow: var(--shadow-md);
      }

      .section-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        color: var(--text);
        margin-bottom: 1.2rem;
      }

      .table-wrap {
        overflow-x: auto;
        border-radius: 20px;
        border: 1px solid var(--line-soft);
      }

      .tours-table {
        width: 100%;
        border-collapse: collapse;
        background: #fff;
      }

      .tours-table th {
        background: #1b4e2b;
        color: #fff;
        padding: 1rem;
        text-align: left;
        font-weight: 700;
        font-size: 0.92rem;
      }

      .tours-table td {
        padding: 1rem;
        border-bottom: 1px solid var(--line-soft);
        vertical-align: middle;
      }

      .tours-table tr:hover {
        background: #fbfdf9;
      }

      .tour-image {
        width: 64px;
        height: 44px;
        object-fit: cover;
        border-radius: 10px;
      }

      .tour-name {
        font-weight: 700;
        color: var(--text);
      }

      .tour-location {
        color: var(--text-muted);
        font-size: 0.88rem;
      }

      .price {
        font-weight: 800;
        color: var(--primary);
      }

      .actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .btn {
        padding: 0.5rem 0.85rem;
        border: none;
        border-radius: 12px;
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-1px);
      }

      .btn-view {
        background: var(--primary-soft);
        color: var(--primary);
      }

      .btn-delete {
        background: #fbe6e4;
        color: var(--danger);
      }

      .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
      }

      .empty-state i {
        font-size: 4rem;
        margin-bottom: 1rem;
        color: #9eb6a3;
      }

      .empty-state h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 2.2rem;
        color: var(--text);
        margin-bottom: 0.5rem;
      }

      @media (max-width: 991px) {
        .stats-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .header-content {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (max-width: 767px) {
        .container {
          padding: 1.2rem;
        }

        .stats-grid {
          grid-template-columns: 1fr;
        }

        .dashboard-header {
          flex-direction: column;
        }

        .header-actions {
          width: 100%;
        }

        .action-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="header">
      <div class="header-content">
        <div class="admin-title">
          <i class="fas fa-shield-alt"></i>
          OrbitRush Admin
        </div>
        <div class="admin-nav">
          <a href="/">
            <i class="fas fa-home"></i>
            Public Site
          </a>
          <a href="/tour/admin/create">
            <i class="fas fa-plus"></i>
            Add Tour
          </a>
          <a href="/user/logout" class="nav-strong">
            <i class="fas fa-sign-out-alt"></i>
            Logout
          </a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="dashboard-header">
        <div class="page-title-wrap">
          <h1>Dashboard Overview</h1>
          <p>
            Manage tours, monitor enquiries, and keep the admin workspace aligned
            with the same OrbitRush brand theme.
          </p>
        </div>
        <div class="header-actions">
          <a href="/tour/admin/create" class="action-btn primary">
            <i class="fas fa-plus"></i>
            Create New Tour
          </a>
          <a href="/tour/admin/dashboard/user-details" class="action-btn secondary">
            <i class="fas fa-users"></i>
            View All Users
          </a>
          <a href="/tour/admin/dashboard/enquiries-details" class="action-btn secondary">
            <i class="fas fa-envelope-open"></i>
            View All Enquiries
          </a>
        </div>
      </div>

      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-icon"><i class="fas fa-route"></i></div>
          <div class="stat-content">
            <h3><%= tours.length %></h3>
            <p>Total Tours</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
          <div class="stat-content">
            <h3><%= totalEnquiries %></h3>
            <p>Total Enquiries</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon revenue"><i class="fas fa-rupee-sign"></i></div>
          <div class="stat-content">
            <h3>&#8377;<%= tours.reduce((sum, tour) => sum + tour.price, 0).toLocaleString() %></h3>
            <p>Total Revenue Value</p>
          </div>
        </div>
        <div class="stat-card">
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-content">
            <h3><%= totalUsers %></h3>
            <p>Active Users</p>
          </div>
        </div>
      </div>

      <div class="tours-section">
        <h2 class="section-title">
          <i class="fas fa-map-marked-alt me-2"></i>
          Manage Tours
        </h2>

        <% if (tours && tours.length > 0) { %>
        <div class="table-wrap">
          <table class="tours-table">
            <thead>
              <tr>
                <th>Tour</th>
                <th>Location</th>
                <th>Duration</th>
                <th>Price</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% tours.forEach(tour => { %>
              <tr>
                <td>
                  <div style="display: flex; align-items: center; gap: 1rem">
                    <img
                      src="<%= tour.coverImage || '/images/default-tour.jpg' %>"
                      alt="<%= tour.name %>"
                      class="tour-image"
                    />
                    <div>
                      <div class="tour-name"><%= tour.name %></div>
                      <div class="tour-location">
                        <i class="fas fa-eye me-1"></i> Views: 245
                      </div>
                    </div>
                  </div>
                </td>
                <td><i class="fas fa-map-marker-alt me-1"></i><%= tour.location %></td>
                <td><i class="far fa-clock me-1"></i><%= tour.duration %></td>
                <td class="price">&#8377;<%= tour.price.toLocaleString() %></td>
                <td><%= new Date(tour.createdAt).toLocaleDateString() %></td>
                <td>
                  <div class="actions">
                    <a
                      href="/tour/<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>"
                      class="btn btn-view"
                      target="_blank"
                    >
                      <i class="fas fa-eye"></i>
                      View
                    </a>

                    <button
                      onclick="deleteTour('<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>', '<%= tour.name %>')"
                      class="btn btn-delete"
                    >
                      <i class="fas fa-trash"></i>
                      Delete
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
        <div class="empty-state">
          <i class="fas fa-map-signs"></i>
          <h3>No Tours Created Yet</h3>
          <p>Start by creating your first amazing tour package.</p>
          <a
            href="/tour/admin/create"
            class="action-btn primary"
            style="margin-top: 1rem; display: inline-flex;"
          >
            <i class="fas fa-plus"></i>
            Create First Tour
          </a>
        </div>
        <% } %>
      </div>
    </div>

    <script>
      function deleteTour(tourSlug, tourName) {
        if (
          confirm(
            `Are you sure you want to delete "${tourName}"?\n\nThis action cannot be undone and will also delete all related comments and images.`
          )
        ) {
          const deleteBtn = event.target;
          const originalText = deleteBtn.innerHTML;
          deleteBtn.innerHTML =
            '<i class="fas fa-spinner fa-spin"></i> Deleting...';
          deleteBtn.disabled = true;

          fetch(`/tour/${tourSlug}`, {
            method: "DELETE",
            headers: {
              "Content-Type": "application/json",
            },
          })
            .then((response) => response.json())
            .then((data) => {
              if (data.message === "Tour deleted successfully") {
                alert("Tour deleted successfully!");
                window.location.reload();
              } else {
                throw new Error(data.message || "Failed to delete tour");
              }
            })
            .catch((error) => {
              console.error("Error:", error);
              alert("Error deleting tour: " + error.message);
              deleteBtn.innerHTML = originalText;
              deleteBtn.disabled = false;
            });
        }
      }

      document.addEventListener("DOMContentLoaded", function () {
        const statCards = document.querySelectorAll(".stat-card");
        statCards.forEach((card, index) => {
          card.style.opacity = "0";
          card.style.transform = "translateY(16px)";
          setTimeout(() => {
            card.style.transition = "opacity 0.45s ease, transform 0.45s ease";
            card.style.opacity = "1";
            card.style.transform = "translateY(0)";
          }, index * 90);
        });
      });
    </script>
  </body>
</html>
