<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title>Explore Tours | OrbitRush Tourism</title>
    <style>
      .tours-hero {
        padding: 3rem 0 2rem;
        background: linear-gradient(180deg, #f2f8f0 0%, #fbfcf8 100%);
      }

      .collection-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        padding: 1.2rem 1.4rem;
        margin-top: 2rem;
      }

      .collection-bar strong {
        font-size: 1.05rem;
      }

      .collection-bar p {
        margin: 0.3rem 0 0;
        color: var(--text-muted);
      }

      .tours-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .tour-card {
        overflow: hidden;
        border-radius: 28px;
      }

      .tour-media {
        position: relative;
        aspect-ratio: 1.08 / 0.82;
        overflow: hidden;
      }

      .tour-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .tour-top-tag,
      .tour-price-chip {
        position: absolute;
        z-index: 1;
        border-radius: 999px;
        font-weight: 700;
      }

      .tour-top-tag {
        top: 1rem;
        left: 1rem;
        padding: 0.45rem 0.85rem;
        background: rgba(255, 255, 255, 0.92);
        color: #5e7f67;
        font-size: 0.8rem;
        text-transform: uppercase;
      }

      .tour-price-chip {
        right: 1rem;
        bottom: 1rem;
        padding: 0.45rem 0.75rem;
        background: var(--gold);
        color: #1d4023;
        font-size: 0.86rem;
      }

      .tour-location {
        position: absolute;
        left: 1rem;
        bottom: 1rem;
        color: #fff;
        z-index: 1;
        font-weight: 600;
      }

      .tour-body {
        padding: 1.35rem;
      }

      .tour-title {
        margin: 0 0 0.6rem;
        font-family: "Cormorant Garamond", serif;
        font-size: 1.32rem;
        line-height: 1;
      }

      .tour-overview {
        color: var(--text-muted);
        line-height: 1.75;
        min-height: 5.2rem;
        margin-bottom: 1rem;
      }

      .tour-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.95rem;
      }

      .tour-tags span {
        padding: 0.28rem 0.62rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: #64826b;
        font-size: 0.8rem;
        font-weight: 600;
      }

      .tour-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        color: var(--text-muted);
        font-size: 0.92rem;
        margin-bottom: 1rem;
        font-weight: 600;
      }

      .tour-footer {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 1rem;
        border-top: 1px solid var(--line-soft);
        padding-top: 1rem;
      }

      .tour-footer small {
        display: block;
        color: #9aab9e;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.75rem;
        font-weight: 700;
      }

      .tour-footer strong {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.95rem;
        line-height: 1;
      }

      .empty-state {
        padding: 4rem 2rem;
        text-align: center;
      }

      @media (max-width: 1199px) {
        .tours-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 767px) {
        .tours-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body class="page-shell">
    <%- include("partials/nav") %>

    <main>
      <section class="tours-hero">
        <div class="container">
          <div class="section-heading">
            <span class="section-kicker">Explore Packages</span>
            <h1>Featured Tours</h1>
            <p>
              Discover handpicked journeys styled in the same visual language as
              your homepage so every new tour feels consistent and polished.
            </p>
          </div>

          <div class="panel-card collection-bar">
            <div>
              <strong><%= tours ? tours.length : 0 %> tours available</strong>
              <p>Every tour you add will automatically use this card design.</p>
            </div>
            <a href="/contact-us" class="btn-ghost-brand">Need help choosing?</a>
          </div>
        </div>
      </section>

      <section class="section-space pt-4">
        <div class="container">
          <% if (tours && tours.length > 0) { %>
          <div class="tours-grid">
            <% tours.forEach((tour, index) => { 
              const tags = (tour.included && tour.included.length > 0)
                ? tour.included.slice(0, 3)
                : [tour.location, tour.duration, "Guided Tour"];
              const labels = ["Best Seller", "Top Rated", "International", "Adventure"];
            %>
            <article class="panel-card tour-card">
              <div class="tour-media">
                <img src="<%= tour.coverImage || '/images/default.png' %>" alt="<%= tour.name %>" />
                <span class="tour-top-tag"><%= labels[index % labels.length] %></span>
                <div class="tour-location">📍 <%= tour.location %></div>
                <span class="tour-price-chip">★ <%= (4.5 + ((index % 5) * 0.1)).toFixed(1) %></span>
              </div>

              <div class="tour-body">
                <h2 class="tour-title"><%= tour.name %></h2>
                <div class="tour-tags">
                  <% tags.forEach((tag) => { %>
                  <span><%= tag %></span>
                  <% }) %>
                </div>
                <p class="tour-overview">
                  <%= tour.overview.length > 150 ? tour.overview.slice(0, 150) + '...' : tour.overview %>
                </p>
                <div class="tour-meta">
                  <span><i class="far fa-clock me-1"></i><%= tour.duration %></span>
                  <span><i class="fas fa-users me-1"></i>Max 20</span>
                  <span><i class="fas fa-suitcase-rolling me-1"></i>Moderate</span>
                </div>
                <div class="tour-footer">
                  <div>
                    <small>From</small>
                    <strong>&#8377;<%= tour.price.toLocaleString('en-IN') %></strong>
                  </div>
                  <a
                    href="/tour/<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>"
                    class="btn-brand"
                    style="min-width: 132px; min-height: 46px; border-radius: 999px;"
                  >
                    View Details
                  </a>
                </div>
              </div>
            </article>
            <% }) %>
          </div>
          <% } else { %>
          <div class="panel-card empty-state">
            <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2.3rem;">No tours yet</h2>
            <p class="text-secondary mb-0">
              As soon as you add tours, they’ll appear here with the same themed layout.
            </p>
          </div>
          <% } %>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %> <%- include("partials/scripts") %>
  </body>
</html>
