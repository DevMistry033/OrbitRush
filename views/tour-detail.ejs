<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title><%= tour.name %> | OrbitRush Tourism</title>
    <style>
      .detail-hero {
        position: relative;
        min-height: 520px;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(12, 31, 21, 0.28), rgba(12, 31, 21, 0.65)),
          url("<%= tour.coverImage || '/images/default.png' %>") center/cover no-repeat;
      }

      .detail-hero-content {
        position: relative;
        z-index: 1;
        min-height: 520px;
        display: flex;
        align-items: end;
        padding: 4rem 0 3rem;
        color: #fff;
      }

      .detail-hero-inner {
        max-width: 760px;
      }

      .detail-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.7rem 1.15rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.22);
        color: #e4eee5;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.82rem;
        font-weight: 700;
      }

      .detail-title {
        margin: 1rem 0 0.85rem;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(3.4rem, 7vw, 5.6rem);
        line-height: 0.92;
        color: #fff;
      }

      .detail-copy {
        color: rgba(255, 255, 255, 0.88);
        line-height: 1.85;
        font-size: 1.05rem;
      }

      .detail-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        margin-top: 1.4rem;
      }

      .detail-pill {
        padding: 0.7rem 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
        font-weight: 600;
      }

      .detail-wrap {
        margin-top: -84px;
        position: relative;
        z-index: 2;
      }

      .detail-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.75fr);
        gap: 1.5rem;
      }

      .stack {
        display: grid;
        gap: 1.5rem;
      }

      .content-card,
      .booking-card {
        padding: 1.6rem;
      }

      .content-card h2,
      .booking-card h3 {
        margin-bottom: 1rem;
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        color: var(--text);
      }

      .content-card p {
        color: var(--text-muted);
        line-height: 1.85;
      }

      .facts-grid,
      .date-grid,
      .gallery-grid,
      .includes-grid,
      .review-list {
        display: grid;
        gap: 1rem;
      }

      .facts-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .fact-box,
      .date-badge,
      .itinerary-day,
      .list-box,
      .review-card {
        border-radius: 20px;
        background: var(--surface-soft);
        border: 1px solid var(--line-soft);
      }

      .fact-box {
        padding: 1.2rem;
      }

      .fact-box strong {
        display: block;
        margin-top: 0.55rem;
        font-size: 1.05rem;
      }

      .itinerary-day {
        padding: 1.2rem;
      }

      .itinerary-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.7rem;
      }

      .day-chip {
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        background: var(--primary);
        color: #fff;
        font-weight: 700;
      }

      .gallery-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .gallery-grid img {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 20px;
        object-fit: cover;
      }

      .includes-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .list-box {
        padding: 1.25rem;
      }

      .list-box h4 {
        margin-bottom: 0.9rem;
        font-size: 1.12rem;
        font-weight: 700;
      }

      .list-box ul {
        margin: 0;
        padding-left: 1.15rem;
        color: var(--text-muted);
        line-height: 1.9;
      }

      .booking-card {
        position: sticky;
        top: 105px;
      }

      .booking-price {
        display: flex;
        align-items: end;
        gap: 0.5rem;
        margin-bottom: 0.6rem;
      }

      .booking-price strong {
        font-family: "Cormorant Garamond", serif;
        font-size: 3rem;
        line-height: 1;
      }

      .booking-sub {
        color: var(--text-muted);
        line-height: 1.8;
      }

      .booking-actions {
        display: grid;
        gap: 0.85rem;
        margin: 1.4rem 0;
      }

      .date-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .date-badge {
        padding: 0.9rem 1rem;
        color: var(--text);
        font-weight: 600;
      }

      .support-box {
        margin-top: 1rem;
        padding: 1rem 1.1rem;
        border-radius: 18px;
        background: var(--primary-soft);
        color: #4b6b53;
        line-height: 1.8;
      }

      .star-rating {
        display: flex;
        gap: 0.45rem;
        margin-bottom: 1rem;
      }

      .star {
        font-size: 1.8rem;
        color: #d0dacd;
        cursor: pointer;
      }

      .star.active,
      .star.selected {
        color: var(--gold);
      }

      .review-card {
        padding: 1.2rem;
      }

      .review-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.8rem;
      }

      .reviewer {
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .review-avatar {
        width: 44px;
        height: 44px;
        border-radius: 999px;
        background: #3f8a54;
        color: #fff;
        display: grid;
        place-items: center;
        font-weight: 700;
      }

      .review-stars {
        color: var(--gold);
      }

      @media (max-width: 991px) {
        .detail-layout,
        .facts-grid,
        .gallery-grid,
        .includes-grid,
        .date-grid {
          grid-template-columns: 1fr;
        }

        .booking-card {
          position: static;
        }
      }
    </style>
  </head>

  <body class="page-shell">
    <%- include("partials/nav") %>

    <main>
      <section class="detail-hero">
        <div class="container detail-hero-content">
          <div class="detail-hero-inner">
            <div class="detail-badge">
              <i class="fas fa-location-dot"></i>
              <%= tour.location %>
            </div>
            <h1 class="detail-title"><%= tour.name %></h1>
            <p class="detail-copy"><%= tour.overview %></p>
            <div class="detail-pills">
              <span class="detail-pill"><i class="far fa-clock me-2"></i><%= tour.duration %></span>
              <span class="detail-pill"><i class="fas fa-wallet me-2"></i>&#8377;<%= tour.price.toLocaleString('en-IN') %> per person</span>
              <span class="detail-pill"><i class="fas fa-shield-heart me-2"></i>Secure booking support</span>
            </div>
          </div>
        </div>
      </section>

      <section class="detail-wrap section-space pb-0">
        <div class="container">
          <div class="detail-layout">
            <div class="stack">
              <section class="panel-card content-card">
                <h2>Quick Overview</h2>
                <div class="facts-grid">
                  <div class="fact-box">
                    <i class="fas fa-map-location-dot"></i>
                    <strong>Destination</strong>
                    <span><%= tour.location %></span>
                  </div>
                  <div class="fact-box">
                    <i class="far fa-clock"></i>
                    <strong>Duration</strong>
                    <span><%= tour.duration %></span>
                  </div>
                  <div class="fact-box">
                    <i class="fas fa-star"></i>
                    <strong>Style</strong>
                    <span>Curated guided experience</span>
                  </div>
                </div>
              </section>

              <% if (tour.itinerary && tour.itinerary.length > 0) { %>
              <section class="panel-card content-card">
                <h2>Itinerary</h2>
                <div class="review-list">
                  <% tour.itinerary.forEach((day) => { %>
                  <article class="itinerary-day">
                    <div class="itinerary-top">
                      <span class="day-chip">Day <%= day.day %></span>
                      <strong><%= day.title %></strong>
                    </div>
                    <p class="mb-0"><%= day.description %></p>
                  </article>
                  <% }) %>
                </div>
              </section>
              <% } %>

              <% if (tour.moreImages && tour.moreImages.length > 0) { %>
              <section class="panel-card content-card">
                <h2>Gallery</h2>
                <div class="gallery-grid">
                  <% tour.moreImages.forEach((image) => { %>
                  <img src="<%= image %>" alt="<%= tour.name %> gallery image" />
                  <% }) %>
                </div>
              </section>
              <% } %>

              <section class="panel-card content-card">
                <h2>What's Included</h2>
                <div class="includes-grid">
                  <div class="list-box">
                    <h4><i class="fas fa-circle-check text-success me-2"></i>Included</h4>
                    <ul>
                      <% (tour.included && tour.included.length ? tour.included : ['Professional guidance', 'Trip coordination', 'Essential travel support']).forEach((item) => { %>
                      <li><%= item %></li>
                      <% }) %>
                    </ul>
                  </div>
                  <div class="list-box">
                    <h4><i class="fas fa-circle-xmark text-danger me-2"></i>Excluded</h4>
                    <ul>
                      <% (tour.excluded && tour.excluded.length ? tour.excluded : ['Personal expenses', 'Optional upgrades', 'Anything not mentioned above']).forEach((item) => { %>
                      <li><%= item %></li>
                      <% }) %>
                    </ul>
                  </div>
                </div>
              </section>

              <section class="panel-card content-card">
                <h2>Reviews & Comments</h2>

                <% if (user) { %>
                <form
                  method="POST"
                  action="/tour/<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>/comment"
                >
                  <label class="form-label fw-semibold">Your Rating</label>
                  <div class="star-rating" id="starRating">
                    <span class="star" data-rating="1">&#9733;</span>
                    <span class="star" data-rating="2">&#9733;</span>
                    <span class="star" data-rating="3">&#9733;</span>
                    <span class="star" data-rating="4">&#9733;</span>
                    <span class="star" data-rating="5">&#9733;</span>
                  </div>
                  <input type="hidden" name="rating" id="ratingValue" required />

                  <label for="content" class="form-label fw-semibold">Your Review</label>
                  <textarea
                    id="content"
                    name="content"
                    class="form-control"
                    rows="5"
                    placeholder="Share your experience about this tour..."
                    required
                  ></textarea>

                  <button type="submit" class="btn-brand mt-3" id="submitBtn" disabled>
                    Post Review
                  </button>
                </form>
                <hr class="my-4" />
                <% } %>

                <% if (comments && comments.length > 0) { %>
                <div class="review-list">
                  <% comments.forEach((comment) => { %>
                  <article class="review-card">
                    <div class="review-top">
                      <div class="reviewer">
                        <div class="review-avatar">
                          <%= comment.createdBy.fullName.charAt(0).toUpperCase() %>
                        </div>
                        <div>
                          <strong><%= comment.createdBy.fullName %></strong>
                          <div class="text-secondary" style="font-size: 0.9rem;">
                            <%= new Date(comment.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                          </div>
                        </div>
                      </div>
                      <div class="review-stars">
                        <% for (let i = 1; i <= 5; i++) { %>
                        <i class="fas fa-star <%= comment.rating >= i ? '' : 'opacity-25' %>"></i>
                        <% } %>
                      </div>
                    </div>
                    <p class="mb-0"><%= comment.content %></p>
                  </article>
                  <% }) %>
                </div>
                <% } else { %>
                <p class="mb-0 text-secondary">No reviews yet. Be the first traveler to share your experience.</p>
                <% } %>
              </section>
            </div>

            <aside>
              <div class="panel-card booking-card">
                <h3>Book This Tour</h3>
                <div class="booking-price">
                  <strong>&#8377;<%= tour.price.toLocaleString('en-IN') %></strong>
                  <span class="text-secondary">/ person</span>
                </div>
                <p class="booking-sub">
                  Keep the same original booking and enquiry flow, now presented in a
                  cleaner themed sidebar.
                </p>

                <div class="booking-actions">
                  <button class="btn-brand border-0" onclick="proceedToBooking()">
                    <i class="fas fa-calendar-check"></i>
                    Book Now
                  </button>
                  <button class="btn-ghost-brand" onclick="bookTour()">
                    <i class="fas fa-envelope"></i>
                    Enquire Now
                  </button>
                </div>

                <% if (tour.availableDates && tour.availableDates.length > 0) { %>
                <div>
                  <h3 style="font-size: 1.45rem;">Available Dates</h3>
                  <div class="date-grid">
                    <% tour.availableDates.slice(0, 6).forEach((date) => { %>
                    <div class="date-badge">
                      <i class="far fa-calendar me-2"></i>
                      <%= new Date(date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    </div>
                    <% }) %>
                  </div>
                </div>
                <% } %>

                <div class="support-box">
                  <strong class="d-block mb-2">Need help deciding?</strong>
                  <div>Call: +91 98765 43210</div>
                  <div>Email: orbitrushtourism@gmail.com</div>
                  <div>Support: 24/7 customer assistance</div>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %> <%- include("partials/scripts") %>

    <script>
      function proceedToBooking() {
        window.location.href = "/booking/book/<%= tour._id %>";
      }

      function bookTour() {
        window.location.href = "/tour/enquire";
      }

      document.addEventListener("DOMContentLoaded", function () {
        const stars = document.querySelectorAll(".star");
        const ratingValue = document.getElementById("ratingValue");
        const submitBtn = document.getElementById("submitBtn");
        let currentRating = 0;

        function paintStars(rating, hoverMode) {
          stars.forEach((star) => {
            const value = Number(star.dataset.rating);
            star.classList.remove("active", "selected");
            if (value <= rating) {
              star.classList.add(hoverMode ? "active" : "selected");
            }
          });
        }

        stars.forEach((star) => {
          star.addEventListener("mouseenter", function () {
            paintStars(Number(this.dataset.rating), true);
          });

          star.addEventListener("click", function () {
            currentRating = Number(this.dataset.rating);
            ratingValue.value = currentRating;
            paintStars(currentRating, false);
            if (submitBtn) submitBtn.disabled = false;
          });
        });

        const ratingWrap = document.getElementById("starRating");
        if (ratingWrap) {
          ratingWrap.addEventListener("mouseleave", function () {
            paintStars(currentRating, false);
          });
        }
      });
    </script>
  </body>
</html>
