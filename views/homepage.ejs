<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title>OrbitRush Tourism | Discover Amazing Destinations</title>
    <style>
      .hero-shell {
        position: relative;
        min-height: 660px;
        overflow: hidden;
        background: #183c28;
      }

      .hero-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease;
        background-size: cover;
        background-position: center;
      }

      .hero-slide.active {
        opacity: 1;
      }

      .hero-overlay {
        position: absolute;
        inset: 0;
        background:
          linear-gradient(180deg, rgba(12, 32, 22, 0.42), rgba(12, 32, 22, 0.58)),
          rgba(24, 60, 40, 0.18);
      }

      .hero-inner {
        position: relative;
        z-index: 1;
        min-height: 660px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #fff;
        padding: 4rem 0 6rem;
      }

      .hero-content {
        max-width: 820px;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.8rem;
        padding: 0.8rem 1.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.28);
        background: rgba(255, 255, 255, 0.12);
        color: #d9ead8;
        font-size: 0.9rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .hero-badge::before,
      .hero-badge::after {
        content: "";
        width: 1rem;
        height: 2px;
        background: rgba(217, 234, 216, 0.72);
      }

      .hero-title {
        margin: 1.4rem 0 1rem;
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(4rem, 8vw, 7.4rem);
        line-height: 0.9;
        letter-spacing: -0.06em;
        color: #fff;
        font-weight: 700;
      }

      .hero-title .accent {
        color: var(--gold);
        font-style: italic;
      }

      .hero-copy {
        max-width: 760px;
        margin: 0 auto;
        color: rgba(255, 255, 255, 0.86);
        font-size: 1.08rem;
        line-height: 1.8;
      }

      .hero-actions {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2rem;
      }

      .hero-cta {
        min-width: 190px;
        min-height: 66px;
        padding: 1rem 2rem;
        border-radius: 999px;
        font-size: 1.1rem;
        font-weight: 700;
      }

      .hero-cta-secondary {
        background: rgba(255, 255, 255, 0.18);
        color: #fff;
        border: 2px solid rgba(255, 255, 255, 0.6);
      }

      .hero-cta-secondary:hover {
        background: rgba(255, 255, 255, 0.28);
        color: #fff;
      }

      .hero-dots {
        position: absolute;
        left: 50%;
        bottom: 1.6rem;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        gap: 0.5rem;
      }

      .hero-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.45);
        border: none;
        cursor: pointer;
      }

      .hero-dot.active {
        width: 28px;
        background: var(--gold);
      }

      .stats-strip {
        background: #0f4c1f;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .stat-item {
        text-align: center;
        padding: 1.35rem 1rem;
        border-right: 1px solid rgba(255, 255, 255, 0.1);
      }

      .stat-item:last-child {
        border-right: none;
      }

      .stat-icon {
        font-size: 1.2rem;
      }

      .search-block {
        padding: 1.6rem 0;
        background: #fff;
      }

      .search-bar {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr auto;
        border: 1px solid var(--line);
        border-radius: 26px;
        overflow: hidden;
        background: #fff;
      }

      .search-group {
        padding: 0.95rem 1.35rem;
        border-right: 1px solid var(--line-soft);
      }

      .search-group:last-of-type {
        border-right: none;
      }

      .search-label {
        display: block;
        margin-bottom: 0.35rem;
        color: #8aa08c;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.75rem;
        font-weight: 700;
      }

      .search-group input,
      .search-group select {
        width: 100%;
        border: none !important;
        background: transparent;
        padding: 0 !important;
        color: var(--text);
        font-size: 1rem;
        font-weight: 600;
      }

      .search-group input:focus,
      .search-group select:focus {
        box-shadow: none !important;
      }

      .search-submit {
        min-width: 180px;
        border-radius: 0;
        border: none;
      }

      .deal-strip {
        background: #1f6b33;
        color: #fff;
      }

      .deal-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.8rem 0;
        flex-wrap: wrap;
      }

      .deal-copy {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        color: rgba(255, 255, 255, 0.92);
        font-weight: 600;
      }

      .deal-copy strong {
        color: var(--gold);
      }

      .featured-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .tour-card {
        overflow: hidden;
        border-radius: 28px;
      }

      .tour-media {
        position: relative;
        aspect-ratio: 1.1 / 0.82;
        overflow: hidden;
      }

      .tour-media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .tour-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(13, 42, 22, 0.06), rgba(13, 42, 22, 0.3));
      }

      .tour-badge,
      .tour-heart,
      .tour-rating {
        position: absolute;
        z-index: 1;
      }

      .tour-badge {
        top: 1rem;
        left: 1rem;
        padding: 0.45rem 0.9rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        color: #5a7e62;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
      }

      .tour-heart {
        top: 1rem;
        right: 1rem;
        width: 38px;
        height: 38px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.94);
        color: #d8d9d2;
        display: grid;
        place-items: center;
      }

      .tour-location-bar {
        position: absolute;
        left: 1rem;
        bottom: 1rem;
        color: #fff;
        font-weight: 600;
      }

      .tour-rating {
        right: 1rem;
        bottom: 1rem;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        background: var(--gold);
        color: #194124;
        font-size: 0.85rem;
        font-weight: 700;
      }

      .tour-body {
        padding: 1.35rem 1.4rem 1.45rem;
      }

      .tour-title {
        margin: 0 0 0.55rem;
        font-family: "Cormorant Garamond", serif;
        font-size: 1.3rem;
        line-height: 1;
        color: var(--text);
      }

      .tour-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-bottom: 0.9rem;
      }

      .tour-tags span {
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: #63876d;
        font-size: 0.8rem;
        font-weight: 600;
      }

      .tour-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.95rem;
        color: var(--text-muted);
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 1rem;
      }

      .tour-footer {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        border-top: 1px solid var(--line-soft);
        padding-top: 1rem;
      }

      .tour-price-label {
        display: block;
        color: #a4b0a3;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .tour-price {
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        line-height: 1;
        color: var(--text);
        font-weight: 700;
      }

      .tour-detail-btn {
        min-width: 124px;
        min-height: 46px;
        border-radius: 999px;
      }

      .destinations-grid {
        display: grid;
        grid-template-columns: 1.6fr 1fr 1fr;
        gap: 1rem;
      }

      .destination-card {
        position: relative;
        overflow: hidden;
        min-height: 250px;
        border-radius: 28px;
      }

      .destination-card.large {
        grid-row: span 2;
        min-height: 520px;
      }

      .destination-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .destination-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(7, 27, 16, 0.02), rgba(7, 27, 16, 0.7));
      }

      .destination-copy {
        position: absolute;
        left: 1.5rem;
        right: 1.5rem;
        bottom: 1.3rem;
        z-index: 1;
        color: #fff;
      }

      .destination-copy h3 {
        margin: 0 0 0.25rem;
        font-family: "Cormorant Garamond", serif;
        font-size: 1.5rem;
      }

      .review-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.2rem;
      }

      .review-card {
        padding: 1.5rem;
        min-height: 270px;
      }

      .review-stars {
        color: var(--gold);
        letter-spacing: 0.14em;
        font-size: 0.9rem;
      }

      .review-quote {
        margin: 1rem 0 1.5rem;
        color: #728874;
        line-height: 1.9;
        font-style: italic;
        font-weight: 500;
      }

      .reviewer {
        display: flex;
        align-items: center;
        gap: 0.9rem;
      }

      .reviewer-avatar {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        background: #3d8c53;
        color: #fff;
        display: grid;
        place-items: center;
        font-weight: 700;
      }

      .floating-actions {
        position: fixed;
        left: 1rem;
        bottom: 1rem;
        z-index: 20;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }

      .floating-actions a {
        width: 46px;
        height: 46px;
        border-radius: 999px;
        display: grid;
        place-items: center;
        text-decoration: none;
        color: #fff;
        box-shadow: var(--shadow-sm);
      }

      .floating-actions .chat-btn {
        background: linear-gradient(135deg, #48dd73, #1fb95f);
      }

      .floating-actions .top-btn {
        background: #1b4e2b;
      }

      .empty-home {
        padding: 4rem 2rem;
        text-align: center;
      }

      @media (max-width: 1199px) {
        .featured-grid,
        .review-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 991px) {
        .stats-grid,
        .search-bar,
        .featured-grid,
        .destinations-grid,
        .review-grid {
          grid-template-columns: 1fr;
        }

        .stat-item {
          border-right: none;
          border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }

        .search-group {
          border-right: none;
          border-bottom: 1px solid var(--line-soft);
        }

        .destination-card.large {
          grid-row: auto;
          min-height: 360px;
        }

        .hero-inner,
        .hero-shell {
          min-height: 580px;
        }
      }

      @media (max-width: 767px) {
        .hero-title {
          font-size: clamp(3.2rem, 16vw, 4.8rem);
        }

        .hero-content {
          padding: 0 0.9rem;
        }

        .hero-cta {
          width: 100%;
        }

        .review-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>

  <body class="page-shell">
    <%- include("partials/nav") %>

    <main>
      <%
        const heroImages = (tours && tours.length > 0)
          ? tours.slice(0, 4).map((tour) => tour.coverImage).filter(Boolean)
          : [];
        const fallbackHeroImages = [
          "https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1600&q=80",
          "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1600&q=80",
          "https://images.unsplash.com/photo-1528127269322-539801943592?auto=format&fit=crop&w=1600&q=80"
        ];
        const slides = heroImages.length > 0 ? heroImages : fallbackHeroImages;
        const destinationMap = {};
        (tours || []).forEach((tour) => {
          if (tour.location && !destinationMap[tour.location]) {
            destinationMap[tour.location] = {
              name: tour.location,
              image: tour.coverImage || "/images/default.png",
              count: 1
            };
          } else if (tour.location) {
            destinationMap[tour.location].count += 1;
          }
        });
        const destinations = Object.values(destinationMap).slice(0, 5);
      %>

      <section class="hero-shell">
        <% slides.forEach((image, index) => { %>
        <div
          class="hero-slide <%= index === 0 ? 'active' : '' %>"
          style="background-image: url('<%= image %>')"
        ></div>
        <% }) %>
        <div class="hero-overlay"></div>

        <div class="container hero-inner">
          <div class="hero-content">
            <div class="hero-badge">Where Nature Calls</div>
            <h1 class="hero-title">
              Discover <span class="accent">Amazing</span><br />
              Destinations
            </h1>
            <p class="hero-copy">
              Explore breathtaking locations around the world with our carefully
              curated tour packages. Create unforgettable memories and embark on
              the adventure of a lifetime.
            </p>

            <div class="hero-actions">
              <a href="/tour" class="btn-brand-secondary hero-cta">
                <i class="fas fa-seedling"></i>
                Explore Tours
              </a>
              <% if (user) { %>
              <a href="/profile" class="btn-ghost-brand hero-cta hero-cta-secondary">
                <i class="fas fa-user"></i>
                My Profile
              </a>
              <% } else { %>
              <a href="/user/signin" class="btn-ghost-brand hero-cta hero-cta-secondary">
                Sign In
              </a>
              <% } %>
            </div>
          </div>
        </div>

        <div class="hero-dots">
          <% slides.forEach((_, index) => { %>
          <button class="hero-dot <%= index === 0 ? 'active' : '' %>" data-slide="<%= index %>"></button>
          <% }) %>
        </div>
      </section>

      <section class="stats-strip">
        <div class="container">
          <div class="stats-grid">
            <div class="metric-card stat-item">
              <div class="stat-icon">🗺️</div>
              <span class="metric-value"><%= Math.max((destinations.length || 0), 6) %>+</span>
              <span class="metric-label">Destinations</span>
            </div>
            <div class="metric-card stat-item">
              <div class="stat-icon">😊</div>
              <span class="metric-value">10K+</span>
              <span class="metric-label">Happy Travelers</span>
            </div>
            <div class="metric-card stat-item">
              <div class="stat-icon">⭐</div>
              <span class="metric-value">4.9★</span>
              <span class="metric-label">Avg Rating</span>
            </div>
            <div class="metric-card stat-item">
              <div class="stat-icon">🏆</div>
              <span class="metric-value">5 Yrs</span>
              <span class="metric-label">Experience</span>
            </div>
            <div class="metric-card stat-item">
              <div class="stat-icon">📞</div>
              <span class="metric-value">24/7</span>
              <span class="metric-label">Support</span>
            </div>
          </div>
        </div>
      </section>

      <section class="search-block">
        <div class="container">
          <form action="/tour" method="get" class="search-bar">
            <div class="search-group">
              <label class="search-label">Where To</label>
              <input type="text" name="destination" placeholder="Destination or tour name..." />
            </div>
            <div class="search-group">
              <label class="search-label">Category</label>
              <select name="category">
                <option>All Types</option>
                <option>Adventure</option>
                <option>Family</option>
                <option>Luxury</option>
                <option>International</option>
              </select>
            </div>
            <div class="search-group">
              <label class="search-label">Max Budget (₹)</label>
              <input type="text" name="budget" placeholder="Any budget..." />
            </div>
            <button type="submit" class="btn-brand search-submit">
              Search Tours <i class="fas fa-arrow-right"></i>
            </button>
          </form>
        </div>
      </section>

      <section class="deal-strip">
        <div class="container">
          <div class="deal-inner">
            <div class="deal-copy">
              <span><strong>🔥 SUMMER SALE:</strong> Up to 20% off on Kashmir & Spiti tours — Limited seats!</span>
              <span>✈ Free cancellation up to 24 hrs</span>
              <span>🛡 100% Secure Booking</span>
              <span>📞 24/7 Support</span>
            </div>
            <a href="/tour" class="btn-brand-secondary" style="min-height: 44px; padding: 0.7rem 1.3rem; border-radius: 999px;">
              View All Deals →
            </a>
          </div>
        </div>
      </section>

      <section class="section-space">
        <div class="container">
          <div class="section-heading">
            <span class="section-kicker">Our Packages</span>
            <h2>Featured Tours</h2>
            <p>
              Discover our most popular destinations and create memories that will
              last a lifetime
            </p>
          </div>

          <% if (tours && tours.length > 0) { %>
          <div class="featured-grid">
            <% tours.slice(0, 8).forEach((tour, index) => { 
              const tags = (tour.included && tour.included.length > 0)
                ? tour.included.slice(0, 3)
                : [tour.location, tour.duration, "Guided Tour"];
              const labelPool = ["Best Seller", "Top Rated", "International", "Adventure"];
              const label = labelPool[index % labelPool.length];
              const derivedRating = 4.5 + ((index % 5) * 0.1);
            %>
            <article class="panel-card tour-card">
              <div class="tour-media">
                <img src="<%= tour.coverImage || '/images/default.png' %>" alt="<%= tour.name %>" />
                <div class="tour-overlay"></div>
                <span class="tour-badge"><%= label %></span>
                <span class="tour-heart"><i class="far fa-heart"></i></span>
                <div class="tour-location-bar">📍 <%= tour.location %></div>
                <span class="tour-rating">⭐ <%= derivedRating.toFixed(1) %></span>
              </div>

              <div class="tour-body">
                <h3 class="tour-title"><%= tour.name %></h3>
                <div class="tour-tags">
                  <% tags.forEach((tag) => { %>
                  <span><%= tag %></span>
                  <% }) %>
                </div>
                <div class="tour-meta">
                  <span><i class="far fa-clock me-1"></i><%= tour.duration %></span>
                  <span><i class="fas fa-users me-1"></i>Max 20</span>
                  <span><i class="fas fa-briefcase me-1"></i>Moderate</span>
                </div>
                <div class="tour-footer">
                  <div>
                    <span class="tour-price-label">From</span>
                    <div class="tour-price">&#8377;<%= tour.price.toLocaleString('en-IN') %></div>
                  </div>
                  <a
                    href="/tour/<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>"
                    class="btn-brand tour-detail-btn"
                  >
                    View Details
                  </a>
                </div>
              </div>
            </article>
            <% }) %>
          </div>
          <% } else { %>
          <div class="panel-card empty-home">
            <h3 class="mb-3" style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem;">Featured tours will appear here automatically.</h3>
            <p class="mb-0 text-secondary">
              When you add tours from the admin side, they’ll render in this same card design.
            </p>
          </div>
          <% } %>
        </div>
      </section>

      <section class="section-space pt-0">
        <div class="container">
          <div class="section-heading">
            <span class="section-kicker">Explore By Region</span>
            <h2>Popular Destinations</h2>
            <p>Browse by region and discover the beauty of each place</p>
          </div>

          <% if (destinations.length > 0) { %>
          <div class="destinations-grid">
            <% destinations.forEach((destination, index) => { %>
            <article class="destination-card <%= index === 0 ? 'large' : '' %>">
              <img src="<%= destination.image %>" alt="<%= destination.name %>" />
              <div class="destination-overlay"></div>
              <div class="destination-copy">
                <h3><%= destination.name %></h3>
                <span><%= destination.count %> tour<%= destination.count > 1 ? 's' : '' %> available</span>
              </div>
            </article>
            <% }) %>
          </div>
          <% } else { %>
          <div class="panel-card empty-home">
            <h3 class="mb-3" style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem;">Destinations will grow with your tours.</h3>
            <p class="mb-0 text-secondary">
              As you add tours, this region section will automatically pick up their locations and cover images.
            </p>
          </div>
          <% } %>
        </div>
      </section>

      <section class="section-space pt-0" style="background: linear-gradient(180deg, #f6fbf5 0%, #eef6ef 100%);">
        <div class="container">
          <div class="section-heading">
            <span class="section-kicker">Traveler Reviews</span>
            <h2>Real Stories, Real Memories</h2>
            <p>Thousands of travelers have trusted OrbitRush for their journeys</p>
          </div>

          <% if (comments && comments.length > 0) { %>
          <div class="review-grid">
            <% comments.forEach((comment) => { %>
            <article class="panel-card review-card">
              <div class="review-stars">
                <% for (let i = 1; i <= 5; i++) { %>
                <i class="fas fa-star"></i>
                <% } %>
              </div>
              <p class="review-quote">
                "<%= comment.content.length > 135 ? comment.content.slice(0, 135) + '...' : comment.content %>"
              </p>
              <div class="reviewer">
                <div class="reviewer-avatar">
                  <%= comment.createdBy && comment.createdBy.fullName ? comment.createdBy.fullName.charAt(0).toUpperCase() : 'O' %>
                </div>
                <div>
                  <strong><%= comment.createdBy && comment.createdBy.fullName ? comment.createdBy.fullName : 'OrbitRush Traveler' %></strong>
                  <div class="text-secondary" style="font-size: 0.9rem;">
                    📍 <%= comment.tourId && comment.tourId.name ? comment.tourId.name : 'Featured Journey' %>
                  </div>
                </div>
              </div>
            </article>
            <% }) %>
          </div>
          <% } else { %>
          <div class="panel-card empty-home">
            <h3 class="mb-3" style="font-family: 'Cormorant Garamond', serif; font-size: 2.2rem;">Traveler reviews will show here automatically.</h3>
            <p class="mb-0 text-secondary">
              Once users start rating and reviewing tours, this section will match the same testimonial style from your reference.
            </p>
          </div>
          <% } %>
        </div>
      </section>
    </main>

    <div class="floating-actions">
      <a href="/contact-us" class="chat-btn" title="Contact us">
        <i class="fas fa-comment"></i>
      </a>
      <a href="#" class="top-btn" title="Back to top">
        <i class="fas fa-arrow-up"></i>
      </a>
    </div>

    <%- include("partials/footer") %> <%- include("partials/scripts") %>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const slides = document.querySelectorAll(".hero-slide");
        const dots = document.querySelectorAll(".hero-dot");
        if (!slides.length) return;

        let currentIndex = 0;

        function showSlide(index) {
          slides.forEach((slide, slideIndex) => {
            slide.classList.toggle("active", slideIndex === index);
          });
          dots.forEach((dot, dotIndex) => {
            dot.classList.toggle("active", dotIndex === index);
          });
          currentIndex = index;
        }

        dots.forEach((dot, index) => {
          dot.addEventListener("click", function () {
            showSlide(index);
          });
        });

        setInterval(function () {
          showSlide((currentIndex + 1) % slides.length);
        }, 4000);
      });
    </script>
  </body>
</html>
