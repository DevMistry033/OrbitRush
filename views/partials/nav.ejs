<nav class="navbar navbar-expand-lg fixed-top site-navbar" id="mainNavbar">
  <div class="container">
    <div
      class="navbar-container d-flex w-100 align-items-center justify-content-between"
    >
      <a class="navbar-brand" href="/">
        <img
          src="/images/1760177356614.png"
          alt="OrbitRush Logo"
          width="48"
          height="48"
          class="brand-mark"
        />
        <span>OrbitRush</span>
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNavDropdown"
        aria-controls="navbarNavDropdown"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarNavDropdown">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/about-us">About Us</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/contact-us">Contact</a>
          </li>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="/tour"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              Tours
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if (locals.tours && locals.tours.length > 0) { %> <% locals.tours.forEach((tour) => { %>
              <li>
                <a
                  class="dropdown-item"
                  href="/tour/<%= tour.name.replace(/\s+/g, '-').toLowerCase() %>"
                  title="<%= tour.name %>"
                >
                  <i class="fas fa-location-dot me-2"></i><%= tour.name %>
                </a>
              </li>
              <% }) %> <% } else { %>
              <li>
                <span class="dropdown-item text-muted">
                  <i class="fas fa-circle-info me-2"></i>No tours available yet
                </span>
              </li>
              <% } %>
            </ul>
          </li>

          <% if (locals.user) { %>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <span class="nav-user-chip">
                <img src="<%= locals.user.profileImageURL %>" alt="Profile" />
                <span><%= locals.user.fullName %></span>
              </span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <a class="dropdown-item" href="/profile">
                  <i class="fas fa-user me-2"></i>My Profile
                </a>
              </li>

              <% if (locals.user.role === 'ADMIN') { %>
              <li>
                <a class="dropdown-item" href="/tour/admin/dashboard">
                  <i class="fas fa-chart-line me-2"></i>Admin Dashboard
                </a>
              </li>
              <li>
                <a
                  class="dropdown-item"
                  href="/tour/admin/dashboard/enquiries-details"
                >
                  <i class="fas fa-clipboard-list me-2"></i>All Enquiries
                </a>
              </li>
              <li>
                <a class="dropdown-item" href="/booking/admin/bookings">
                  <i class="fas fa-calendar-check me-2"></i>All Bookings
                </a>
              </li>
              <% } else { %>
              <li>
                <a class="dropdown-item" href="/my-enquiries">
                  <i class="fas fa-clipboard-list me-2"></i>My Enquiries
                </a>
              </li>
              <li>
                <a class="dropdown-item" href="/booking/my-bookings">
                  <i class="fas fa-ticket me-2"></i>My Bookings
                </a>
              </li>
              <% } %>

              <li><hr class="dropdown-divider" /></li>
              <li>
                <a class="dropdown-item" href="/user/logout">
                  <i class="fas fa-right-from-bracket me-2"></i>Logout
                </a>
              </li>
            </ul>
          </li>
          <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/user/signin">Sign In</a>
          </li>
          <li class="nav-item">
            <a class="btn-brand ms-lg-2 mt-3 mt-lg-0" href="/user/signup">
              Start Planning
            </a>
          </li>
          <% } %>
        </ul>
      </div>
    </div>
  </div>
</nav>

<% if (locals.error) { %>
<div class="site-alert text-center">
  <i class="fas fa-triangle-exclamation me-2"></i><%= locals.error %>
</div>
<% } %>

<script>
  window.addEventListener("scroll", function () {
    const navbar = document.getElementById("mainNavbar");
    if (window.scrollY > 50) {
      navbar.classList.add("is-scrolled");
    } else {
      navbar.classList.remove("is-scrolled");
    }
  });
</script>
