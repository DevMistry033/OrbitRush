<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include("partials/head") %>
    <title>Contact Us | OrbitRush Tourism</title>
    <style>
      .contact-hero {
        padding: 4rem 0 2rem;
        background: linear-gradient(180deg, #f3f8f0 0%, #fbfcf8 100%);
      }

      .contact-grid,
      .hours-grid {
        display: grid;
        gap: 1.5rem;
      }

      .contact-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .contact-card,
      .hours-card {
        padding: 1.5rem;
      }

      .contact-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        display: grid;
        place-items: center;
        background: var(--primary-soft);
        color: var(--primary);
        margin-bottom: 1rem;
      }

      .contact-card h3,
      .hours-card h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 2rem;
        margin-bottom: 0.6rem;
      }

      .contact-main {
        font-weight: 700;
        color: var(--text);
        margin-bottom: 0.7rem;
      }

      .contact-card p,
      .hours-card p {
        color: var(--text-muted);
        line-height: 1.8;
      }

      .hours-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      @media (max-width: 991px) {
        .contact-grid,
        .hours-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body class="page-shell">
    <%- include("partials/nav") %>

    <main>
      <section class="contact-hero">
        <div class="container">
          <div class="section-heading">
            <span class="section-kicker">Contact OrbitRush</span>
            <h1>Stay in touch through a cleaner, more professional contact experience.</h1>
            <p>
              The contact page now matches the new homepage theme while keeping your
              same phone, email, and map links unchanged.
            </p>
          </div>
        </div>
      </section>

      <section class="section-space pt-3">
        <div class="container">
          <div class="contact-grid">
            <article class="panel-card contact-card">
              <div class="contact-icon"><i class="fas fa-phone"></i></div>
              <h3>Call Us</h3>
              <div class="contact-main">+91 7862801349</div>
              <p>Speak directly with our travel team for quick assistance and personalized planning.</p>
              <a href="tel:+917862801349" class="btn-brand mt-2">Call Now</a>
            </article>

            <article class="panel-card contact-card">
              <div class="contact-icon"><i class="fas fa-envelope"></i></div>
              <h3>Email Us</h3>
              <div class="contact-main">orbitrushtourism@gmail.com</div>
              <p>Send us details about your trip and we’ll respond with the right guidance and next steps.</p>
              <a href="mailto:orbitrushtourism@gmail.com" class="btn-brand mt-2">Send Email</a>
            </article>

            <article class="panel-card contact-card">
              <div class="contact-icon"><i class="fas fa-location-dot"></i></div>
              <h3>Visit Us</h3>
              <div class="contact-main">Faculty of Technology</div>
              <p>Meet us in person for travel discussions, recommendations, and booking guidance.</p>
              <a
                href="https://maps.app.goo.gl/CQdDe2q5MaAtYxLu6"
                target="_blank"
                class="btn-brand mt-2"
              >
                Get Directions
              </a>
            </article>
          </div>
        </div>
      </section>

      <section class="section-space pt-0">
        <div class="container">
          <div class="hours-grid">
            <article class="panel-card hours-card">
              <span class="section-kicker">Weekdays</span>
              <h3>Monday - Friday</h3>
              <p>9:00 AM - 8:00 PM</p>
            </article>
            <article class="panel-card hours-card">
              <span class="section-kicker">Weekend</span>
              <h3>Saturday - Sunday</h3>
              <p>10:00 AM - 6:00 PM</p>
            </article>
          </div>
        </div>
      </section>
    </main>

    <%- include("partials/footer") %> <%- include("partials/scripts") %>
  </body>
</html>
